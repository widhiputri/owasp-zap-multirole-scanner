      "post": {
        "summary": "Login",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email":    { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/rest/user/whoami": {
      "get": {
        "summary": "Get current user info",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/rest/user/change-password": {
      "get": {
        "summary": "Change password",
        "parameters": [
          { "name": "current", "in": "query", "schema": { "type": "string" } },
          { "name": "new",     "in": "query", "schema": { "type": "string" } },
          { "name": "repeat",  "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
